<p class="text-green-400"><%= notice %></p>

<%= render @post, title_classes: "text-2xl", subtitle_classes: "text-base mt-3" %>
<hr class="h-px border border-gray-500 mb-5">
<article class="prose prose-lg dark:prose-invert">
  <%= parse_markdown(@post.body) %>
</article>
<%# <hr class="mt-5"> %>


<%= button_to "Delete this post", 
  post_path(@post), 
  method: :delete, 
  data: {turbo_confirm: "Are you sure?"}, 
  class: "mt-5 underline text-red-400 text-sm" if authenticated?
%>